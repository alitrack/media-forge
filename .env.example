# MediaForge LLM Configuration (OpenAI-compatible)
# Copy this to .env and fill in your credentials
#
# Works with: DeepSeek, OpenAI, Ollama, vLLM, Groq, SiliconFlow, etc.
# Any provider with an OpenAI-compatible chat completions endpoint.

OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
MEDIAFORGE_MODEL=deepseek-chat

# Other provider examples (uncomment one):
#
# OpenAI:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   MEDIAFORGE_MODEL=gpt-4o-mini
#
# Ollama (local):
#   OPENAI_API_KEY=not-needed
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   MEDIAFORGE_MODEL=qwen3:latest
#
# SiliconFlow (cheap CN):
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.siliconflow.cn/v1
#   MEDIAFORGE_MODEL=Qwen/Qwen3-32B

# TTS Backend Configuration
# Default: edge-tts (free, no key required)
# MEDIAFORGE_TTS_BACKEND=edge

# Azure Cognitive Services Speech (commercial license)
# For production-quality Chinese + English TTS with SSML support.
# Get credentials from Azure Portal → Speech Service → Keys and Endpoint.
# AZURE_SPEECH_KEY=YourAzureSpeechKey
# AZURE_SPEECH_REGION=eastasia
# Then use: mediaforge podcast --tts-backend azure ...
#
# Available voices for --voice (azure backend):
#   Chinese: xiaoxiao (female), yunyang (male), yunxi (male),
#            xiaoyi (female), yunjian (male)
#   English: aria (female), jenny (female), guy (male)
#   Multilingual: xiaoxiao_multilingual, yunyang_multilingual

